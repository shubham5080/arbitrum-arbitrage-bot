{
  "name": "arbitrum-arbitrage-bot",
  "version": "1.0.0",
  "description": "33-day empirical research on Arbitrum DEX arbitrage — spot, stablecoin, and triangular routes",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:quotes": "npx ts-node src/test/runQuotePoolTests.ts",
    "research:alpha": "npx ts-node src/tools.ts alpha-discovery",
    "research:expansion": "npx ts-node src/tools.ts expansion-validation",
    "research:stablecoin": "npx ts-node src/tools.ts stablecoin-research",
    "research:strategy": "npx ts-node src/tools.ts strategy-report",
    "research:triangle": "npx ts-node src/tools.ts triangle-research",
    "research:final-validation": "npx ts-node src/tools.ts final-validation",
    "triangle:monitor": "npx ts-node src/triangular/triangleMonitor.ts",
    "stablecoin:collect": "npx ts-node src/stablecoin/stablecoinCollector.ts",
    "stablecoin:scan": "npx ts-node src/tools.ts stablecoin-scan",
    "test:contracts": "hardhat test test/FlashLoanArbitrage.test.js test/FlashLoanRoute.test.js",
    "deploy:sepolia": "hardhat run scripts/deployFlashLoan.ts --network arbitrumSepolia",
    "execute:sepolia": "hardhat run scripts/executeSepoliaRoute.ts --network arbitrumSepolia"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@uniswap/v3-core": "^1.0.1",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@aave/core-v3": "^1.19.3",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "@openzeppelin/contracts": "^5.6.1",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.1",
    "chai": "^6.2.2",
    "ethers": "^6.16.0",
    "hardhat": "^2.19.5",
    "hardhat-gas-reporter": "^2.3.0",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^6.0.3"
  }
}
